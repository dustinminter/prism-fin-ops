SNOWFLAKE_ACCOUNT=<archetype-account-locator>
SNOWFLAKE_USER=<service_user>
SNOWFLAKE_WAREHOUSE=PRISM_APP_WH
SNOWFLAKE_DATABASE=FEDERAL_FINANCIAL_DATA
SNOWFLAKE_SCHEMA=EOTSS_STAGING
SNOWFLAKE_ROLE=PRISM_APP_ROLE

# Auth: use ONE of the following
SNOWFLAKE_PRIVATE_KEY_PATH=<path-to-rsa_key.p8>
# SNOWFLAKE_PASSWORD=<password>

# Socrata Open Data API (data.mass.gov) — optional but recommended to avoid throttling
# Register at: https://data.mass.gov/profile/edit/developer_settings
SOCRATA_APP_TOKEN=
