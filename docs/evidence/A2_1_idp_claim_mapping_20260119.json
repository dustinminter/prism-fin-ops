  "idp_claim_mapping": {
    "description": "Required IdP claims for PRISM SSO integration",
    "required_claims": [
      {
        "claim": "sub",
        "description": "Unique user identifier from IdP"
      },
      {
        "claim": "email",
        "description": "User email address"
      },
      {
        "claim": "name",
        "description": "Display name"
      },
      {
        "claim": "prism_agency_id",
        "description": "User's primary agency code"
      },
      {
        "claim": "prism_secretariat_id",
        "description": "User's secretariat code"
      },
      {
        "claim": "prism_role",
        "description": "PRISM role level (VIEWER|ANALYST|ADMIN|EXECUTIVE)"
      },
      {
        "claim": "prism_groups",
        "description": "Array of group memberships"
      }
    ],
    "role_mapping_rules": [
      {
        "condition": "prism_groups contains '{secretariat}_EXEC' AND prism_role == 'EXECUTIVE'",
        "snowflake_role": "{secretariat}_EXECUTIVE"
      },
      {
        "condition": "prism_groups contains '{secretariat}_FINOPS' AND prism_role == 'ANALYST'",
        "snowflake_role": "{secretariat}_FINOPS_ANALYST"
      },
      {
        "condition": "prism_role == 'ANALYST'",
        "snowflake_role": "AGENCY_{agency_id}_ANALYST"
      },
      {
        "condition": "prism_role == 'VIEWER'",
        "snowflake_role": "AGENCY_{agency_id}_VIEWER"
      }
    ]
  }
