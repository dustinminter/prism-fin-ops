# Terraform state (contains secrets)
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Terraform working directories
.terraform/
.terraform.lock.hcl

# Variable files with secrets
terraform.tfvars
*.auto.tfvars

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
